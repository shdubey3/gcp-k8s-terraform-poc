# terraform.tfvars.example
# ──────────────────────────────────────────────────────────────────────────────
# Copy this to terraform.tfvars and uncomment/adjust what you need.
#
# REQUIRED – set via shell environment (never commit real values):
#
#   export MY_PROJECT="your-gcp-project-id"
#   export MY_CIDR="$(curl -s ifconfig.me)/32"   # auto-detected if unset
#   source setenv.sh
#
# Then run: terraform plan / terraform apply
# ──────────────────────────────────────────────────────────────────────────────

# ── Cluster ───────────────────────────────────────────────────────────────────
cluster = {
  name              = "andromeda"
  region            = "us-west1"
  gke_version       = "1.34.4-gke.1130000"
  release_channel   = "STABLE"       # RAPID | REGULAR | STABLE
  node_locations    = ["us-west1-a"]
  max_pods_per_node = 110
}

# ── Networking ────────────────────────────────────────────────────────────────
network = {
  vpc_name            = "main-network"
  subnet_name         = "main-subnet"
  vpc_cidr            = "10.0.0.0/16"
  subnet_cidr         = "10.0.1.0/24"
  pods_range_name     = "main-pods"
  pods_cidr           = "10.1.0.0/16"
  services_range_name = "main-services"
  services_cidr       = "10.2.0.0/16"
  allowed_ssh_cidr    = "0.0.0.0/0"  # tighten to your IP in production
}

# ── Node Pool ─────────────────────────────────────────────────────────────────
node_pool = {
  name          = "default-pool"
  machine_type  = "e2-medium"
  disk_size_gb  = 100
  disk_type     = "pd-balanced"    # pd-standard | pd-ssd | pd-balanced
  image_type    = "COS_CONTAINERD"
  initial_count = 3
  min_count     = 3
  max_count     = 10
}

# ── Node Auto-Provisioning ────────────────────────────────────────────────────
autoprovisioning = {
  min_cpu    = 1
  max_cpu    = 10
  min_memory = 1
  max_memory = 64
  locations  = ["us-west1-a"]
}

# ── Labels ────────────────────────────────────────────────────────────────────
labels = {
  environment = "poc"
  managed_by  = "terraform"
}
